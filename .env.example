# =================================================================
# MailMind — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# =================================================================

# --- NextAuth / Auth.js ---------------------------------------------------
# Generate a secret with: openssl rand -base64 32
# (or run: npx auth secret  — Auth.js helper)
AUTH_SECRET=replace-with-a-long-random-string

# Set to your deployed URL on Vercel; for local dev keep http://localhost:3000
AUTH_URL=http://localhost:3000

# --- Google OAuth (for sign-in) -----------------------------------------
# Create at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs:
#   - http://localhost:3000/api/auth/callback/google   (dev)
#   - https://YOUR-APP.vercel.app/api/auth/callback/google   (prod)
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# --- Cloud service #1: Google Gemini API (AI text generation) -------------
# Get a key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# --- Cloud service #2: Resend (email delivery) ----------------------------
# Get a key at: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# Sender address — for free testing, use "onboarding@resend.dev"
# (Resend allows sending FROM that address only TO your verified Resend account email)
# To send to anyone, verify a custom domain in Resend.
RESEND_FROM=MailMind <onboarding@resend.dev>

# --- Cloud service #3: Supabase (sent-email history per user) -------------
# Create a project at https://supabase.com (free tier).
# Then run the SQL in db/schema.sql once via the Supabase SQL Editor.
# Get the values from: Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# IMPORTANT: use the *service_role* key (server-only — never expose to the browser).
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...your-service-role-key
